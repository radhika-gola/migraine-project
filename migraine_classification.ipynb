      "[5 rows x 9 columns]\n"
     ]
    }
   ],
   "source": [
    "df['date'] = pd.to_datetime(df['date'])\n",
    "df = df.sort_values(by=['user_id', 'date']).reset_index(drop=True)\n",
    "print(df.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "74b82db8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "   user_id       date  ...  sleep_hours_lag1  stress_level_lag1\n",
      "0        1 2024-01-16  ...               7.8                2.0\n",
      "1        1 2024-01-17  ...               6.6                1.0\n",
      "2        1 2024-01-18  ...               8.5                2.0\n",
      "3        1 2024-01-19  ...               7.5                2.0\n",
      "4        1 2024-01-20  ...               9.0                2.0\n",
      "\n",
      "[5 rows x 12 columns]\n"
     ]
    }
   ],
   "source": [
    "# Lag features (previous day's value per user)\n",
    "lag_cols = ['hydration_level','sleep_hours','stress_level']\n",
    "for col in lag_cols:\n",
    "    df[f'{col}_lag1'] = df.groupby('user_id')[col].shift(1)\n",
    "\n",
    "df = df.dropna().reset_index(drop=True)\n",
    "print(df.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "704338a8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "   user_id       date  ...  sleep_hours_roll3  stress_level_roll3\n",
      "0        1 2024-01-19  ...           7.533333            1.666667\n",
      "1        1 2024-01-20  ...           8.333333            2.000000\n",
      "2        1 2024-01-21  ...           8.433333            1.666667\n",
      "3        1 2024-01-22  ...           9.000000            1.333333\n",
      "4        1 2024-01-23  ...           8.366667            1.333333\n",
      "\n",
      "[5 rows x 15 columns]\n"
     ]
    }
   ],
   "source": [
    "# Roll features (rolling mean of previous 3 days per user)\n",
    "roll_cols = ['hydration_level','sleep_hours','stress_level']\n",
    "for col in roll_cols:\n",
    "    df[f\"{col}_roll3\"] = df.groupby('user_id')[col].transform(lambda x: x.shift(1).rolling(3).mean())\n",
    "df = df.dropna().reset_index(drop=True)\n",
    "print(df.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "407665fb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "(9183, 9) (2296, 9) (9183,) (2296,)\n"
     ]
    }
   ],
   "source": [
    "X = df[['hydration_level', 'sleep_hours', 'stress_level', \n",
    "        'hydration_level_lag1', 'sleep_hours_lag1', 'stress_level_lag1',\n",
    "        'hydration_level_roll3', 'sleep_hours_roll3', 'stress_level_roll3']]\n",
    "\n",
    "Y = df['migraine_occurrence']\n",
    "\n",
    "X_train, X_test, Y_train, Y_test = train_test_split(X, Y, test_size=0.2, random_state=42)\n",
    "print(X_train.shape, X_test.shape, Y_train.shape, Y_test.shape)\n"
   ]
  },
